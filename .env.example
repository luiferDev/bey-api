# ============================================================
# Bey API - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=bey_user
DB_PASSWORD=bey_password
DB_NAME=bey_db

# --- Admin ---
ADMIN_EMAIL=admin@bey.com
ADMIN_PASSWORD=Admin123!@#

# --- JWT / Security ---
JWT_SECRET=change-this-to-a-random-secret-key-at-least-32-chars-long
JWT_EXPIRY_HOURS=2
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
JWT_ISSUER=bey_api
JWT_ALGORITHM=HS256

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# --- SMTP (Email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM_NAME=Bey API
EMAIL_FROM_EMAIL=noreply@beyapi.com

# --- OAuth (Google) ---
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# --- Wompi (Payments) ---
WOMPI_ENVIRONMENT=sandbox
WOMPI_PUBLIC_KEY=your-public-key
WOMPI_PRIVATE_KEY=your-private-key
WOMPI_EVENT_KEY=your-event-key
WOMPI_INTEGRITY_KEY=your-integrity-key
WOMPI_BASE_URL=https://sandbox.wompi.co
